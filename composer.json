{
  "name": "yahongie2014/purchase-order",
  "version": "1.0.0",
  "description": "Reusable Laravel package",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.4 <8.5",
    "spatie/laravel-translatable": "^6.0",
    "epartment/nova-dependency-container": "^1.3",
    "mrmonat/nova-translatable": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "PurchaseOrder\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PurchaseOrder\\PurchaseOrderServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
